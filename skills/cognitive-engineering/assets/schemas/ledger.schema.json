{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ce-skill/ledger.schema.json",
  "title": "Research Ledger",
  "description": "Verified-evidence ledger. Κάθε entry είναι ένα 🟢 claim που ΧΡΕΙΑΖΕΤΑΙ source_url + checked_date, αλλιώς είναι UNVERIFIED.",
  "type": "object",
  "required": ["entries"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/entry" }
    }
  },
  "definitions": {
    "entry": {
      "type": "object",
      "required": ["tag", "evidence", "source_url", "checked_date"],
      "additionalProperties": false,
      "properties": {
        "tag": {
          "type": "string",
          "description": "Σύντομο tag/claim id",
          "minLength": 1
        },
        "evidence": {
          "type": "string",
          "description": "Τι ακριβώς λέει η πηγή (όχι παράφραση χωρίς βάση)",
          "minLength": 1
        },
        "source_url": {
          "type": "string",
          "description": "Public URL πηγής — χωρίς αυτό το claim είναι UNVERIFIED",
          "pattern": "^https?://",
          "minLength": 1
        },
        "checked_date": {
          "type": "string",
          "description": "ISO ημερομηνία ελέγχου (YYYY-MM-DD)",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "status": {
          "type": "string",
          "enum": ["green", "probable", "speculative", "anomaly"],
          "description": "Layer· default green αν λείπει"
        }
      }
    }
  }
}
